  .kg-chain-title { font-size: 0.68rem; font-weight: 700; margin-bottom: 10px; color: var(--cyan); }
  .kg-chain-step { display: flex; align-items: flex-start; gap: 8px; padding: 4px 0; font-size: 0.58rem; color: var(--t2); }
  .kg-step-num { width: 18px; height: 18px; border-radius: 50%; background: rgba(6,182,212,0.15); color: var(--cyan); display: flex; align-items: center; justify-content: center; font-size: 0.45rem; font-weight: 800; flex-shrink: 0; }
  .kg-step-label { font-weight: 700; color: var(--t1); margin-right: 4px; }
