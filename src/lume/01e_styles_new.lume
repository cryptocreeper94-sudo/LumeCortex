  .agent-flow-title { font-size: 0.78rem; font-weight: 700; margin-bottom: 1rem; }
  .agent-flow { display: flex; align-items: center; justify-content: center; gap: 4px; flex-wrap: wrap; padding: 1rem; background: var(--card); border-radius: 12px; border: 1px solid var(--glass-border); }
  .flow-node { padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); font-size: 0.55rem; font-weight: 600; text-align: center; line-height: 1.4; background: rgba(255,255,255,0.02); }
  .flow-input { background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.3); color: var(--cyan); font-weight: 800; }
  .flow-output { background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.3); color: #10b981; font-weight: 800; }
