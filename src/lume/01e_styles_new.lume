  .agent-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, currentColor, transparent); opacity: 0.3; }
  .agent-card:hover { border-color: rgba(6,182,212,0.3); transform: translateY(-2px); }
