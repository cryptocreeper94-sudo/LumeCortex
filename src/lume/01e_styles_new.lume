  .kg-stat-label { font-size: 0.45rem; color: var(--t3); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; }
  .kg-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 8px; }
  .kg-domain-card { background: var(--card); border: 1px solid var(--glass-border); border-radius: 10px; padding: 14px; cursor: pointer; transition: all 0.2s; }
  .kg-domain-card:hover { border-color: rgba(6,182,212,0.3); transform: translateY(-2px); }
  .kg-card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .kg-card-icon { font-size: 1.2rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 8px; }
  .kg-card-title { font-size: 0.78rem; font-weight: 700; }
  .kg-card-topics { font-size: 0.58rem; color: var(--t3); margin-bottom: 6px; }
  .kg-topics-num { font-weight: 800; font-family: var(--mono); }
  .kg-card-bar { height: 3px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; margin-bottom: 8px; }
  .kg-card-fill { height: 100%; border-radius: 2px; transition: width 0.5s; }
  .kg-card-subs { display: flex; flex-wrap: wrap; gap: 3px; }
  .kg-sub-badge { font-size: 0.45rem; padding: 1px 6px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 4px; color: var(--t3); }
  .kg-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 10000; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .kg-detail-card { background: var(--bg); border: 1px solid var(--glass-border); border-radius: 16px; max-width: 600px; width: 100%; max-height: 80vh; overflow-y: auto; position: relative; }
  .kg-detail-close { position: absolute; top: 12px; right: 12px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--t2); width: 28px; height: 28px; border-radius: 8px; cursor: pointer; font-size: 0.8rem; display: flex; align-items: center; justify-content: center; }
  .kg-detail-header { padding: 24px 24px 16px; border-bottom: 2px solid; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .kg-detail-icon { font-size: 2rem; }
  .kg-detail-title { font-size: 1.2rem; font-weight: 800; }
  .kg-detail-meta { font-size: 0.55rem; color: var(--t3); font-family: var(--mono); width: 100%; }
  .kg-detail-body { padding: 16px 24px 24px; }
  .kg-detail-subs-title { font-size: 0.6rem; font-weight: 800; color: var(--t3); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
  .kg-detail-sub { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--glass-border); }
  .kg-detail-sub-name { font-size: 0.72rem; font-weight: 600; }
  .kg-detail-sub-stats { font-size: 0.5rem; color: var(--t3); font-family: var(--mono); display: flex; gap: 12px; }
