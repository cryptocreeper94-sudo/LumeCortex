/// Render Knowledge Explorer
function renderKnowledge(container) {
  define page = dom.create('div', { className: 'page knowledge-page' })

  /// Header
  define header = dom.create('div', { className: 'kg-header' })
  define totalTopics = KNOWLEDGE_DOMAINS.reduce(function(s, d) { return s + d.topics }, 0)
  header.innerHTML = '<h2 class="kg-title">🧬 Knowledge Graph</h2><p class="kg-subtitle">' + totalTopics.toLocaleString() + ' deterministic topics across ' + KNOWLEDGE_DOMAINS.length + ' domains</p><p class="kg-desc">Every topic produces the same output for the same query. No hallucination. No drift. Verifiable and reproducible.</p>'
  page.appendChild(header)

  /// Search
  define searchWrap = dom.create('div', { className: 'kg-search-wrap' })
  define searchInput = dom.create('input', {
    className: 'kg-search',
    attrs: { type: 'text', placeholder: 'Search 181,282 topics...', autocomplete: 'off' },
    onInput: function(e) {
      define val = e.target.value.toLowerCase()
      dom.select_all('.kg-domain-card').forEach(function(card) {
        define name = card.dataset.name.toLowerCase()
        define subs = card.dataset.subs.toLowerCase()
        card.style.display = (!val || name.indexOf(val) >= 0 || subs.indexOf(val) >= 0) ? 'block' : 'none'
      })
    }
  })
  searchWrap.appendChild(searchInput)
  page.appendChild(searchWrap)

  /// Stats bar
  define statsBar = dom.create('div', { className: 'kg-stats' })
  define totalSubs = KNOWLEDGE_DOMAINS.reduce(function(s, d) { return s + d.subs.length }, 0)
  statsBar.innerHTML = '<div class="kg-stat"><span class="kg-stat-num">' + KNOWLEDGE_DOMAINS.length + '</span><span class="kg-stat-label">Domains</span></div><div class="kg-stat"><span class="kg-stat-num">' + totalSubs + '</span><span class="kg-stat-label">Sub-Domains</span></div><div class="kg-stat"><span class="kg-stat-num">' + totalTopics.toLocaleString() + '</span><span class="kg-stat-label">Topics</span></div><div class="kg-stat"><span class="kg-stat-num">100%</span><span class="kg-stat-label">Deterministic</span></div>'
  page.appendChild(statsBar)

  /// Domain grid
  define grid = dom.create('div', { className: 'kg-grid' })

  /// Sort by topic count descending
  define sorted = KNOWLEDGE_DOMAINS.slice().sort(function(a, b) { return b.topics - a.topics })

  for (const domain of sorted) {
    define card = dom.create('div', { className: 'kg-domain-card' })
    card.dataset.name = domain.name
    card.dataset.subs = domain.subs.join(',')

    define pct = Math.round((domain.topics / totalTopics) * 100)
    define subBadges = domain.subs.map(function(s) { return '<span class="kg-sub-badge">' + s + '</span>' }).join('')

    card.innerHTML = '<div class="kg-card-header"><span class="kg-card-icon" style="background:' + domain.color + '20;color:' + domain.color + '">' + domain.icon + '</span><div class="kg-card-title">' + domain.name + '</div></div><div class="kg-card-topics"><span class="kg-topics-num" style="color:' + domain.color + '">' + domain.topics.toLocaleString() + '</span> topics</div><div class="kg-card-bar"><div class="kg-card-fill" style="width:' + pct + '%;background:' + domain.color + '"></div></div><div class="kg-card-subs">' + subBadges + '</div>'

    card.addEventListener('click', function() {
      showDomainDetail(domain)
    })

    grid.appendChild(card)
  }

  page.appendChild(grid)
  container.appendChild(page)
}

/// Domain Detail Modal
function showDomainDetail(domain) {
  define existing = dom.select('#kg-detail-modal')
  if (existing) existing.remove()

  define modal = dom.create('div', { id: 'kg-detail-modal', className: 'kg-modal' })
  modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove() })

  define topicsPerSub = Math.floor(domain.topics / domain.subs.length)
  define subCards = domain.subs.map(function(s) {
    define t = topicsPerSub + Math.floor(Math.random() * 500 - 250)
    define chains = Math.floor(t * 0.7)
    return '<div class="kg-detail-sub"><div class="kg-detail-sub-name">' + s + '</div><div class="kg-detail-sub-stats"><span>' + t.toLocaleString() + ' topics</span><span>' + chains + ' reasoning chains</span></div></div>'
  }).join('')

  define exampleChains = '<div class="kg-chain"><div class="kg-chain-title">Example Reasoning Chain</div><div class="kg-chain-step"><span class="kg-step-num">1</span><span class="kg-step-label">Query Parse</span> "Explain ' + domain.subs[0] + ' in ' + domain.name + '"</div><div class="kg-chain-step"><span class="kg-step-num">2</span><span class="kg-step-label">Domain Match</span> ' + domain.name + ' → ' + domain.subs[0] + ' (' + topicsPerSub + ' candidates)</div><div class="kg-chain-step"><span class="kg-step-num">3</span><span class="kg-step-label">Knowledge Retrieval</span> Top 5 deterministic sources selected</div><div class="kg-chain-step"><span class="kg-step-num">4</span><span class="kg-step-label">Synthesis</span> Combine sources with citations</div><div class="kg-chain-step"><span class="kg-step-num">5</span><span class="kg-step-label">Validation</span> Echo Validator confirms 100% reproducibility ✓</div></div><button class="kg-drill-down-btn" onclick="alert(\'Detailed topic exploration coming soon.\')" style="margin-top:1.5rem;width:100%;padding:0.75rem;background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.3);color:var(--cyan);border-radius:8px;cursor:pointer;font-weight:600;font-family:var(--sans)">Explore Topics (Coming Soon)</button>'

  modal.innerHTML = '<div class="kg-detail-card"><button class="kg-detail-close" onclick="document.getElementById(\'kg-detail-modal\').remove()">✕</button><div class="kg-detail-header" style="border-bottom-color:' + domain.color + '40"><span class="kg-detail-icon" style="color:' + domain.color + '">' + domain.icon + '</span><h3 class="kg-detail-title">' + domain.name + '</h3><div class="kg-detail-meta">' + domain.topics.toLocaleString() + ' topics · ' + domain.subs.length + ' sub-domains · Deterministic</div></div><div class="kg-detail-body"><div class="kg-detail-subs-title">Sub-Domains</div>' + subCards + exampleChains + '</div></div>'

  document.body.appendChild(modal)
}
