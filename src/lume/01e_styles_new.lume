  .orch-card-label { font-size: 0.78rem; font-weight: 700; margin-bottom: 4px; }
  .orch-card-desc { font-size: 0.58rem; color: var(--t3); line-height: 1.6; margin-bottom: 10px; }
  .orch-card-flow { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; margin-bottom: 10px; }
  .orch-app-badge { font-size: 0.5rem; padding: 2px 8px; background: rgba(6,182,212,0.08); border: 1px solid rgba(6,182,212,0.15); border-radius: 6px; color: var(--t2); white-space: nowrap; }
  .orch-run-btn { width: 100%; padding: 8px; border: 1px solid rgba(6,182,212,0.2); background: rgba(6,182,212,0.05); color: var(--cyan); border-radius: 8px; font-size: 0.6rem; font-weight: 700; cursor: pointer; font-family: var(--sans); transition: all 0.2s; }
  .orch-run-btn:hover { background: rgba(6,182,212,0.12); }
  .audit-title { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.3rem; }
  .audit-desc { font-size: 0.68rem; color: var(--t3); margin-bottom: 1.5rem; line-height: 1.6; }
  .audit-timeline { position: relative; padding-left: 20px; border-left: 2px solid rgba(255,255,255,0.05); }
  .audit-entry { position: relative; margin-bottom: 12px; padding: 10px 14px; background: var(--card); border: 1px solid var(--glass-border); border-radius: 10px; }
  .audit-time { font-size: 0.45rem; font-family: var(--mono); color: var(--t3); margin-bottom: 4px; }
  .audit-dot { position: absolute; left: -27px; top: 14px; width: 8px; height: 8px; border-radius: 50%; border: 2px solid var(--bg); }
  .audit-agent { font-size: 0.68rem; font-weight: 700; margin-bottom: 4px; }
  .audit-action { font-size: 0.5rem; font-family: var(--mono); background: rgba(255,255,255,0.05); padding: 1px 6px; border-radius: 4px; margin-left: 4px; color: var(--t3); }
  .audit-io { font-size: 0.55rem; color: var(--t2); margin-bottom: 2px; }
  .audit-label { font-weight: 700; color: var(--t3); font-size: 0.5rem; font-family: var(--mono); }
  .audit-hash { font-size: 0.45rem; font-family: var(--mono); color: var(--t3); margin-top: 4px; }
  .audit-verified { color: #10b981; font-weight: 700; }
  .audit-proof { margin-top: 1.5rem; background: rgba(16,185,129,0.04); border: 1px solid rgba(16,185,129,0.15); border-radius: 12px; padding: 20px; text-align: center; }
  .proof-header { font-size: 0.78rem; font-weight: 800; margin-bottom: 12px; }
