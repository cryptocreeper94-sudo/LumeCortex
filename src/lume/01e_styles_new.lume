  .proof-caption { font-size: 0.55rem; color: var(--t3); line-height: 1.6; }
  .repl-page { max-width: 900px; }
  .repl-header { text-align: center; padding: 1rem 0; }
  .repl-title-row { display: flex; align-items: center; justify-content: center; gap: 0.75rem; }
  .repl-title { font-size: 1.3rem; font-weight: 800; }
  .repl-version { font-size: 0.5rem; font-family: var(--mono); color: var(--cyan); padding: 2px 10px; border-radius: 999px; background: rgba(6,182,212,0.08); border: 1px solid rgba(6,182,212,0.15); }
  .repl-subtitle { font-size: 0.68rem; color: var(--t3); margin-top: 0.3rem; line-height: 1.6; }
  .repl-examples { display: flex; align-items: center; gap: 6px; margin-bottom: 1rem; overflow-x: auto; padding-bottom: 4px; }
  .repl-example-btn { padding: 4px 10px; border-radius: 6px; border: 1px solid var(--glass-border); background: var(--card); color: var(--t2); font-size: 0.55rem; font-weight: 600; cursor: pointer; font-family: var(--sans); transition: all 0.2s; white-space: nowrap; }
  .repl-example-btn:hover { border-color: rgba(6,182,212,0.3); color: var(--cyan); }
  .repl-editor-wrap { border-radius: 12px; overflow: hidden; border: 1px solid var(--glass-border); margin-bottom: 1rem; }
  .repl-editor-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; background: rgba(0,0,0,0.3); border-bottom: 1px solid var(--glass-border); }
  .repl-file-tab { display: flex; align-items: center; gap: 6px; }
  .repl-dot { width: 10px; height: 10px; border-radius: 50%; }
  .repl-dot.red { background: #ef4444; }
  .repl-dot.yellow { background: #f59e0b; }
  .repl-dot.green { background: #10b981; }
  .repl-file-name { font-size: 0.6rem; font-family: var(--mono); color: var(--t3); margin-left: 8px; }
  .repl-actions { display: flex; gap: 6px; }
  .repl-run-btn { padding: 5px 14px; border-radius: 6px; border: none; background: linear-gradient(135deg, #10b981, #059669); color: #fff; font-size: 0.6rem; font-weight: 800; cursor: pointer; font-family: var(--sans); transition: all 0.2s; }
  .repl-run-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(16,185,129,0.3); }
  .repl-clear-btn { padding: 5px 12px; border-radius: 6px; border: 1px solid var(--glass-border); background: transparent; color: var(--t3); font-size: 0.6rem; font-weight: 600; cursor: pointer; font-family: var(--sans); }
  .repl-editor-body { display: flex; background: rgba(0,0,0,0.4); }
  .repl-line-nums { padding: 12px 8px; font-size: 0.6rem; font-family: var(--mono); color: var(--t3); text-align: right; min-width: 36px; user-select: none; overflow: hidden; border-right: 1px solid var(--glass-border); line-height: 1.6; }
  .repl-editor { flex: 1; min-height: 220px; padding: 12px; background: transparent; border: none; color: var(--t1); font-size: 0.68rem; font-family: var(--mono); line-height: 1.6; resize: vertical; outline: none; tab-size: 2; }
  .repl-output-wrap { border-radius: 12px; overflow: hidden; border: 1px solid var(--glass-border); margin-bottom: 1rem; }
  .repl-output-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; background: rgba(0,0,0,0.3); border-bottom: 1px solid var(--glass-border); font-size: 0.6rem; font-weight: 700; color: var(--t3); }
  .repl-output-hint { font-size: 0.5rem; font-family: var(--mono); color: var(--t3); }
  .repl-output { padding: 12px; background: rgba(0,0,0,0.4); min-height: 120px; max-height: 300px; overflow-y: auto; }
  .repl-output-line { font-size: 0.62rem; font-family: var(--mono); color: var(--t1); padding: 2px 0; line-height: 1.5; white-space: pre-wrap; word-break: break-all; }
  .repl-output-line.repl-system { color: var(--t3); font-style: italic; }
  .repl-output-line.repl-success { color: #10b981; font-weight: 600; }
  .repl-output-line.repl-error { color: #ef4444; font-weight: 600; }
  .repl-output-line.repl-hash { color: var(--t3); font-size: 0.5rem; opacity: 0.6; }
  .repl-output-line.repl-separator { color: var(--cyan); font-size: 0.5rem; opacity: 0.4; }
  .repl-ref { background: var(--card); border: 1px solid var(--glass-border); border-radius: 12px; padding: 16px; }
  .repl-ref-title { font-size: 0.72rem; font-weight: 700; margin-bottom: 10px; }
  .repl-ref-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 6px; }
  .repl-ref-item { font-size: 0.55rem; color: var(--t3); padding: 4px 0; }
  .repl-ref-item code { font-family: var(--mono); color: var(--cyan); font-size: 0.5rem; background: rgba(6,182,212,0.08); padding: 1px 6px; border-radius: 4px; margin-right: 4px; }
  .knowledge-page { max-width: 900px; }
  .kg-header { text-align: center; padding: 1.5rem 0 1rem; }
  .kg-title { font-size: 1.3rem; font-weight: 800; }
  .kg-subtitle { font-size: 0.78rem; color: var(--cyan); margin-top: 0.2rem; font-weight: 600; }
  .kg-desc { font-size: 0.62rem; color: var(--t3); margin-top: 0.3rem; line-height: 1.6; }
  .kg-search-wrap { margin-bottom: 1rem; }
  .kg-search { width: 100%; padding: 10px 16px; background: var(--card); border: 1px solid var(--glass-border); border-radius: 10px; color: var(--t1); font-size: 0.72rem; font-family: var(--sans); outline: none; transition: border-color 0.2s; box-sizing: border-box; }
  .kg-search:focus { border-color: rgba(6,182,212,0.4); }
