  { name: 'Cybersecurity',       topics: 18420, icon: '🔒', color: '#06b6d4', subs: ['Network Security', 'Cryptography', 'Threat Analysis', 'Penetration Testing', 'Zero Trust', 'SIEM', 'Incident Response'] },
